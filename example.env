# Stackr auto-provisions these variables from .stackr.yaml:
# - STACKR_PROV_POOL_SSD (from paths.pools.SSD)
# - STACKR_PROV_POOL_HDD (from paths.pools.HDD)
# - STACKR_PROV_DOMAIN (auto-generated as <stackname>.<base_domain>)
# - BASE_DOMAIN (from paths.custom.BASE_DOMAIN)
# - MEDIA_STORAGE* (from paths.custom)
#
# Configure these in .stackr.yaml instead of here!

############# owncloud VARS
OWNCLOUD_DOMAIN=oc.yourdomain.com
OWNCLOUD_TRUSTED_DOMAINS=192.168.1.100,oc.yourdomain.com
OWNCLOUD_DB_NAME=owncloud
OWNCLOUD_DB_USERNAME=owncloud
OWNCLOUD_DB_PASSWORD=changeme
OWNCLOUD_DB_ROOT_PASSWORD=changeme
OWNCLOUD_ADMIN_USERNAME=admin
OWNCLOUD_ADMIN_PASSWORD=changeme
######################

############# media VARS
# Shared by jellyfin/sonarr/radarr/prowlarr/bazarr/flaresolverr/rdt-client
PUID=1000
PGID=1000
TZ=Europe/London
REALDEBRID_API_TOKEN=changeme
# Fill these after first boot from each app's Settings -> General
SONARR_API_KEY=changeme
RADARR_API_KEY=changeme
PROWLARR_API_KEY=changeme
BAZARR_API_KEY=changeme
# Match the user/pass you set in RDT-Client's UI
RDT_USER=changeme
RDT_PASS=changeme
# Zilean's Postgres password (any value, kept internal to the stack)
ZILEAN_POSTGRES_PASSWORD=changeme
######################

############# plex VARS
PLEX_CLAIM=claim-YOUR-CLAIM-TOKEN-HERE
######################

############### flame VARS
FLAME_PASSWORD=changeme
#####################

############### immich VARS
# These are relative to the container, not paths on the host
IMMICH_UPLOAD_LOCATION=./images
IMMICH_DB_DATA_LOCATION=./postgres
IMMICH_VERSION=release
IMMICH_DB_PASSWORD=changeme
IMMICH_DB_USERNAME=immich
IMMICH_DB_DATABASE_NAME=postgres
#####################

############### traefik VARS
TRAEFIK_ACME_EMAIL=your-email@example.com
#####################

############### monitoring VARS
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
#####################

############### mx5parts VARS
MX5PARTS_IMAGE_TAG=latest
MX5PARTS_DOMAIN=mx5parts.yourdomain.com
MX5PARTS_POSTGRES_USER=mx5parts
MX5PARTS_POSTGRES_PASSWORD=changeme
MX5PARTS_POSTGRES_DB=mx5parts_store
#####################

############### mumble VARS
MUMBLE_SUPERUSER_PASSWORD=changeme
#####################

############### stackr VARS
STACKR_HOST=0.0.0.0
STACKR_PORT=9000
STACKR_TOKEN=changeme
STACKR_ENV_FILE=.env
STACKR_DOMAIN=stackr.yourdomain.com
STACKR_HOST_REPO_ROOT=/path/to/serverconfig
#####################

############### auth VARS (authelia + lldap)
# Authelia portal: auth.${BASE_DOMAIN}
# lldap admin UI:  lldap.${BASE_DOMAIN}
# LDAP server:     lldap:3890 (internal only)

# Authelia secrets — generate each with:
#   docker run --rm authelia/authelia:4.38 authelia crypto rand --length 64 --charset alphanumeric
AUTHELIA_JWT_SECRET=changeme
AUTHELIA_SESSION_SECRET=changeme
AUTHELIA_STORAGE_ENCRYPTION_KEY=changeme

# Authelia OIDC provider secrets
# HMAC: docker exec authelia authelia crypto rand --length 64 --charset alphanumeric
AUTHELIA_OIDC_HMAC_SECRET=changeme

# Per-OIDC-client secrets (OwnCloud)
# Plaintext (used by OwnCloud's openidconnect app to authenticate to Authelia):
#   docker exec authelia authelia crypto rand --length 72 --charset rfc3986
OWNCLOUD_OIDC_CLIENT_SECRET=changeme
# Hashed form (stored in Authelia). Generate from plaintext above:
#   docker exec authelia authelia crypto hash generate pbkdf2 --variant sha512 --password '<plaintext>'
# Authelia stores the $pbkdf2-sha512$... string. Note: in .env, escape any literal $ as $$
OWNCLOUD_OIDC_CLIENT_SECRET_HASH=changeme

# lldap config
# BASE_DN follows your domain: dc=vulpe,dc=dev
LLDAP_BASE_DN=dc=yourdomain,dc=com
LLDAP_ADMIN_EMAIL=admin@yourdomain.com
# Strong password — also used by Authelia to bind for user lookups
LLDAP_ADMIN_PASSWORD=changeme
# lldap secrets — generate each with:
#   openssl rand -base64 48 | tr -d '\n='
LLDAP_JWT_SECRET=changeme
LLDAP_KEY_SEED=changeme
#####################
